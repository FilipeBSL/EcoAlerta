# ============================================
# EcoAlerta — Variáveis de Ambiente
# Copie este arquivo para .env e preencha
# ============================================

# Ambiente
NODE_ENV=development

# Banco de Dados PostgreSQL
DB_NAME=ecoalerta
DB_USER=ecoalerta
DB_PASS=ecoalerta123

# JWT
JWT_SECRET=sua_chave_secreta_jwt_muito_segura_troque_em_producao
JWT_EXPIRES_IN=24h

# MinIO (Object Storage)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=ecoalerta-fotos

# E-mail (usar Ethereal para desenvolvimento: https://ethereal.email)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=seu_usuario_ethereal
SMTP_PASS=sua_senha_ethereal
SMTP_FROM=noreply@ecoalerta.local

# URLs
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:3001/api/v1

# Limites geográficos do município (bounding box — padrão: São Paulo)
MUNICIPIO_LAT_MIN=-24.0
MUNICIPIO_LAT_MAX=-23.0
MUNICIPIO_LNG_MIN=-47.0
MUNICIPIO_LNG_MAX=-46.0
